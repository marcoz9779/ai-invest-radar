# Phase 2 – News-Provider (Reihenfolge = Priorität)
MARKETAUX_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_KEY=

# Phase 2.5 – Reddit
# Default: läuft anonym über den public JSON-Endpoint, KEINE Credentials nötig.
# Optionales Upgrade: bei reddit.com/prefs/apps eine "script"-App anlegen, dann
# höhere Rate-Limits via PRAW. Falls genutzt, USER_AGENT mit Username anpassen.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-invest-radar/0.1

# Phase 3+ – AI-Sentiment (optional, ~$5/Monat)
ANTHROPIC_API_KEY=

# Phase 4 – Krypto-News mit Vote-Sentiment (gratis Plan, 200 calls/Tag)
# Registrierung: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# Phase 5 – Telegram-Alerts
# 1. Bot bei @BotFather erstellen → Token
# 2. Bot anschreiben → Chat-ID via getUpdates ermitteln
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phase 9 – Deployment-Schutz (Streamlit Cloud)
# Wenn gesetzt, ist die App nur mit ?token=DEIN_TOKEN in der URL erreichbar.
# Lokal optional, im Cloud-Deployment sehr empfohlen.
APP_TOKEN=
